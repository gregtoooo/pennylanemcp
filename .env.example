# Clé API Pennylane — générer depuis : Pennylane > Paramètres > API
PENNYLANE_API_KEY=VOTRE_CLE_ICI

# URL de base de l'API Pennylane (ne pas changer)
PENNYLANE_BASE_URL=https://app.pennylane.com/api/external/v2

# Token d'authentification pour sécuriser le serveur MCP
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=VOTRE_TOKEN_SECRET_ICI

# Origines autorisées (séparées par des virgules)
# Pour Dust : https://dust.tt
ALLOWED_ORIGINS=https://dust.tt
